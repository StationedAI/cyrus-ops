#!/usr/bin/env bash
# devin — thin CLI over the Devin API (api.devin.ai/v1)
# Usage:
#   devin new "<prompt>" [--title <t>] [--tag <tag>]   Create a session, prints session_id + url
#   devin status <session_id>                          Show session status + structured output
#   devin messages <session_id>                        List session messages
#   devin send <session_id> "<message>"                Send a message to a running session
#   devin wait <session_id> [timeout_seconds]          Poll until blocked/finished (default 1800s)
set -euo pipefail

API="https://api.devin.ai/v1"
KEY="${DEVIN_API_KEY:-}"
if [ -z "$KEY" ] && [ -f "$HOME/.cyrus/.env" ]; then
  KEY=$(grep -E '^DEVIN_API_KEY=' "$HOME/.cyrus/.env" | head -1 | cut -d= -f2-)
fi
[ -n "$KEY" ] || { echo "DEVIN_API_KEY not set (env or ~/.cyrus/.env)" >&2; exit 1; }

auth=(-H "Authorization: Bearer $KEY" -H "Content-Type: application/json")

cmd="${1:-}"; shift || true
case "$cmd" in
  new)
    prompt="${1:?prompt required}"; shift || true
    title=""; tag=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --title) title="$2"; shift 2;;
        --tag) tag="$2"; shift 2;;
        *) shift;;
      esac
    done
    body=$(python3 - "$prompt" "$title" "$tag" <<'EOF'
import json,sys
p,t,tag=sys.argv[1],sys.argv[2],sys.argv[3]
d={"prompt":p}
if t: d["title"]=t
if tag: d["tags"]=[tag]
print(json.dumps(d))
EOF
)
    curl -sf "${auth[@]}" -d "$body" "$API/sessions" | python3 -c 'import json,sys;d=json.load(sys.stdin);print(d.get("session_id",""));print(d.get("url",""))'
    ;;
  status)
    sid="${1:?session_id required}"
    curl -sf "${auth[@]}" "$API/session/$sid" | python3 -c 'import json,sys;d=json.load(sys.stdin);print("status:",d.get("status_enum") or d.get("status"));print("title:",d.get("title"));so=d.get("structured_output");print("structured_output:",json.dumps(so)[:2000] if so else None)'
    ;;
  messages)
    sid="${1:?session_id required}"
    curl -sf "${auth[@]}" "$API/session/$sid" | python3 -c '
import json,sys
d=json.load(sys.stdin)
for m in d.get("messages",[]):
    print("[%s] %s" % (m.get("type","?"), (m.get("message") or "")[:1500]))
    print("---")'
    ;;
  send)
    sid="${1:?session_id required}"; msg="${2:?message required}"
    body=$(python3 -c 'import json,sys;print(json.dumps({"message":sys.argv[1]}))' "$msg")
    curl -sf "${auth[@]}" -d "$body" "$API/session/$sid/message" >/dev/null && echo sent
    ;;
  wait)
    sid="${1:?session_id required}"; timeout="${2:-1800}"
    start=$(date +%s)
    while :; do
      st=$(curl -sf "${auth[@]}" "$API/session/$sid" | python3 -c 'import json,sys;d=json.load(sys.stdin);print(d.get("status_enum") or d.get("status") or "")')
      echo "status: $st"
      case "$st" in
        blocked|finished|expired|suspended) break;;
      esac
      [ $(( $(date +%s) - start )) -lt "$timeout" ] || { echo "timeout"; exit 2; }
      sleep 30
    done
    ;;
  *)
    grep '^#   devin' "$0" | sed 's/^#   //'
    exit 1
    ;;
esac
