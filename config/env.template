# ~/.cyrus/.env — values live in the secret store, never in git.
LINEAR_DIRECT_WEBHOOKS=true
CYRUS_BASE_URL=https://atomics-mini.tail230a40.ts.net
CYRUS_SERVER_PORT=3456
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=
# Long-lived subscription token from `claude setup-token` (launchd cannot read the macOS keychain).
CLAUDE_CODE_OAUTH_TOKEN=
# Devin API key (app.devin.ai/settings/api) for the `devin` delegation CLI.
DEVIN_API_KEY=
# --- Observability (Claude Code OpenTelemetry) ---
CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
